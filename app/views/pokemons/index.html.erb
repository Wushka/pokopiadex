<p style="color: green"><%= notice %></p>

<% content_for :title, "Pokemon" %>
<%= link_to "RESET", pokemons_path, class: "font-bold" %>
<div class="flex flex-row">
  <div>
    <% unless @fav.blank?%>
      <p class="font-bold">Favorites</p>
      <% @fav.each do |fav| %>
        <p class="text-2xl">
          <%= fav %>
          <%= link_to "[X]",
          pokemons_path(filter: remove_value_from_filter(@decoded, "fav", fav)),
          data: { turbo_stream: true} %>
        </p>
      <% end %>
    <% end %>
  </div>
  <div>
    <% unless @spec.blank?%>
      <p class="font-bold">Specialities</p>
      <% @spec.each do |spec| %>
        <p class="text-2xl">
          <%= spec %>
          <%= link_to "[X]",
          pokemons_path(filter: remove_value_from_filter(@decoded, "spec", spec)),
          data: { turbo_stream: true} %>
        </p>
      <% end %>
    <% end %>
  </div>
</div>

<table class="border-collapse border-solid border-2 rounded-lg width-fill">
  <thead>
    <tr>
      <th >Name</th>
      <th></th>
      <th>Ideal Habitat</th>
      <th>Speciality</th>
      <th>Favorites</th>
    </tr>
  </thead>
  <tbody>
    <% @pokemons.each do |pokemon| %>
      <tr class="border-solid border-2">
        <td>
          <label class="py-4"><%= pokemon.name %></label>
        </td>
        <td>
          <%= link_to url_for(pokemon) do %>
            <%= image_tag pokemon.full_picture_url%>
          <% end %>
        </td>
        <td>
            <%= link_to pokemon.habitat.name,
            pokemons_path(filter: add_value_to_filter(@decoded, "hab", pokemon.habitat.name)),
            data: { turbo_stream: true} %>
        </td>
        <td>
          <% pokemon.specialities.each do |spec| %>
            <%= link_to spec.name,
            pokemons_path(filter: add_value_to_filter(@decoded, "spec", spec.name)),
            data: { turbo_stream: true} %>
            <br>
          <% end %>
        </td>
        <td>
          <% pokemon.favorites.each do |fav| %>
            <%= link_to fav.name,
            pokemons_path(filter: add_value_to_filter(@decoded, "fav", fav.name)),
            data: { turbo_stream: true} %>
            <br/>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

